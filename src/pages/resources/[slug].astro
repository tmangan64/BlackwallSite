---
// src/pages/resources/[slug].astro
import { getCollection } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('resources', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<EntryLayout
  title={entry.data.title}
  description={entry.data.description}
  tags={entry.data.tags}
  section="Resources"
  sectionHref="/resources"
>
  {entry.data.url && (
    <div style="margin-bottom: 1.5rem;">
      <a href={entry.data.url} target="_blank" rel="noopener"
        style="font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase;">
        {entry.data.url} ↗
      </a>
    </div>
  )}
  <Content />
</EntryLayout>
