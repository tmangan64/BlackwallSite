---
import BaseLayout from '../layouts/BaseLayout.astro';

// Import all content
const projectFiles = await Astro.glob('../content/projects/*.md');
const blogFiles = await Astro.glob('../content/blog/*.md');

const projects = projectFiles
  .map(f => ({ ...f.frontmatter, slug: f.file.split('/').pop()?.replace('.md', '') }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const articles = blogFiles
  .map(f => ({ ...f.frontmatter, slug: f.file.split('/').pop()?.replace('.md', '') }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="[SYSTEM] — Personal Research Log">
  <!-- HERO ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-terminal">
          <div class="terminal-header">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot amber"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">SECURE_SHELL — REMOTE ACCESS NODE</span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">whoami</span></div>
            <div class="terminal-line t-out">[ RUNNER DESIGNATION REDACTED ]</div>
            <div class="terminal-line t-out">[ CLEARANCE LEVEL: PUBLIC ]</div>
            <div class="terminal-spacer"></div>
            <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">cat /etc/motd</span></div>
            <div class="terminal-line t-out">╔══════════════════════════════════════╗</div>
            <div class="terminal-line t-out">║  RESEARCH &amp; DEVELOPMENT TERMINAL    ║</div>
            <div class="terminal-line t-out">║  ALL SESSIONS MONITORED &amp; LOGGED    ║</div>
            <div class="terminal-line t-out">╚══════════════════════════════════════╝</div>
            <div class="terminal-spacer"></div>
            <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">ls ./projects ./articles</span></div>
            <div class="terminal-line t-out green">{projects.length} entries found in ./projects</div>
            <div class="terminal-line t-out green">{articles.length} entries found in ./articles</div>
            <div class="terminal-spacer"></div>
            <div class="terminal-line"><span class="t-prompt">$</span> <span class="t-cursor cursor-blink"></span></div>
          </div>
        </div>

        <div class="hero-text">
          <div class="hero-eyebrow">
            <span class="eyebrow-line"></span>
            <span>PERSONAL LOG — NODE_4A7F</span>
          </div>
          <h1 class="hero-title glitch">
            RESEARCH<br/>
            <span class="hero-title-accent">& DEVELOPMENT</span><br/>
            LOG
          </h1>
          <div class="hero-divider">
            <span class="div-bracket">◄</span>
            <span class="div-line"></span>
            <span class="div-bracket">►</span>
          </div>
          <p class="hero-desc">
            Documenting experiments, projects, and discoveries.
            All content transmitted in plaintext. No encryption.
            No corporate oversight. <span class="highlight-orange">Access unrestricted.</span>
          </p>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-num highlight-cyan">{projects.length}</span>
              <span class="stat-label">PROJECTS</span>
            </div>
            <span class="stat-sep">///</span>
            <div class="stat">
              <span class="stat-num highlight-orange">{articles.length}</span>
              <span class="stat-label">ARTICLES</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEPARATOR -->
  <div class="section-sep">
    <div class="container">
      <div class="sep-line">
        <span class="sep-text">◈ SCROLL DOWN TO ACCESS DATA ARCHIVE ◈</span>
      </div>
    </div>
  </div>

  <!-- PROJECTS ──────────────────────────────────────── -->
  <section id="projects" class="content-section">
    <div class="container">
      <div class="section-header">
        <span class="section-id">01</span>
        <h2>Projects</h2>
        <span class="section-count">{projects.length} entries</span>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <a href={`/projects/${project.slug}`} class="card project-card">
            <div class="card-index">P{String(i + 1).padStart(3, '0')}</div>
            <div class="card-content">
              <div class="card-tags">
                {project.tags?.slice(0, 3).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
                {project.status && (
                  <span class={`tag ${project.status === 'active' ? 'green' : project.status === 'wip' ? 'amber' : 'orange'}`}>
                    {project.status}
                  </span>
                )}
              </div>
              <h3 class="card-title">{project.title}</h3>
              <p class="card-desc">{project.description}</p>
              <div class="card-meta">
                <span class="meta-date">{new Date(project.date).toISOString().slice(0, 10)}</span>
                <span class="meta-arrow">→ ACCESS FILE</span>
              </div>
            </div>
            <div class="card-corner-tl"></div>
            <div class="card-corner-br"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES ──────────────────────────────────────── -->
  <section id="articles" class="content-section">
    <div class="container">
      <div class="section-header">
        <span class="section-id">02</span>
        <h2>Articles</h2>
        <span class="section-count">{articles.length} entries</span>
      </div>

      <div class="articles-list">
        {articles.map((article, i) => (
          <a href={`/blog/${article.slug}`} class="article-row">
            <span class="article-index">A{String(i + 1).padStart(3, '0')}</span>
            <span class="article-date">{new Date(article.date).toISOString().slice(0, 10)}</span>
            <div class="article-info">
              <span class="article-title">{article.title}</span>
              <span class="article-desc">{article.description}</span>
            </div>
            <div class="article-tags">
              {article.tags?.slice(0, 2).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <span class="article-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ─── HERO ─── */
.hero {
  padding: 4rem 0 3rem;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
}

/* Terminal */
.hero-terminal {
  border: 1px solid var(--border-mid);
  background: rgba(4, 14, 24, 0.9);
  font-family: var(--font-mono);
  position: relative;
  animation: fadeUp 0.8s ease both;
}

.hero-terminal::before {
  content: '';
  position: absolute;
  inset: -1px;
  border: 1px solid transparent;
  background: linear-gradient(135deg, var(--accent-cyan), transparent 40%) border-box;
  mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.5;
}

.terminal-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--border-dim);
  background: rgba(0,0,0,0.3);
}

.terminal-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
}
.terminal-dot.red    { background: #ff5f57; }
.terminal-dot.amber  { background: #febc2e; }
.terminal-dot.green  { background: #28c840; }

.terminal-title {
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-left: auto;
}

.terminal-body {
  padding: 1.2rem 1.4rem;
  font-size: 0.82rem;
  min-height: 280px;
}

.terminal-line {
  line-height: 1.6;
  color: var(--text-primary);
}

.terminal-spacer { height: 0.5rem; }

.t-prompt { color: var(--accent-orange); margin-right: 0.5rem; }
.t-cmd { color: var(--accent-cyan); }
.t-out { color: var(--text-secondary); padding-left: 1rem; }
.t-out.green { color: var(--accent-green); }
.t-cursor { display: inline-block; }

/* Hero text */
.hero-text {
  animation: fadeUp 0.8s 0.2s ease both;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--accent-orange);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.eyebrow-line {
  display: inline-block;
  width: 30px;
  height: 1px;
  background: var(--accent-orange);
}

.hero-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1.05;
  letter-spacing: 0.08em;
  margin-bottom: 1.5rem;
  color: var(--text-bright);
}

.hero-title-accent { color: var(--accent-cyan); text-shadow: var(--glow-cyan); }

.hero-divider {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  color: var(--text-dim);
  font-size: 0.7rem;
}

.div-line {
  flex: 1;
  max-width: 120px;
  height: 1px;
  background: linear-gradient(90deg, var(--accent-cyan), transparent);
}

.hero-desc {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.9;
  max-width: 44ch;
  margin-bottom: 2rem;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.stat {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.stat-num {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 700;
  line-height: 1;
}

.stat-label {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  color: var(--text-dim);
  text-transform: uppercase;
}

.stat-sep {
  color: var(--text-dim);
  font-size: 1rem;
  opacity: 0.5;
}

/* ─── SEPARATOR ─── */
.section-sep {
  margin: 3rem 0;
}

.sep-line {
  display: flex;
  align-items: center;
  border-top: 1px solid var(--border-dim);
  border-bottom: 1px solid var(--border-dim);
  padding: 0.5rem 0;
  text-align: center;
  justify-content: center;
}

.sep-text {
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  color: var(--text-dim);
  text-transform: uppercase;
}

/* ─── SECTIONS ─── */
.content-section {
  padding: 3rem 0 4rem;
}

.section-count {
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.1em;
  margin-left: auto;
}

/* ─── PROJECT CARDS ─── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1px;
  background: var(--border-dim);
  border: 1px solid var(--border-dim);
}

@media (max-width: 720px) {
  .projects-grid { grid-template-columns: 1fr; }
}

.project-card {
  display: block;
  text-decoration: none;
  background: var(--bg-panel);
  padding: 1.6rem;
  position: relative;
  transition: all 0.25s ease;
  overflow: hidden;
}

.project-card:hover {
  background: var(--bg-panel-hover);
  transform: none;
}

/* Animated top border on hover */
.project-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-orange));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}

.project-card:hover::after {
  transform: scaleX(1);
}

.card-index {
  font-family: var(--font-terminal);
  font-size: 1.1rem;
  color: var(--text-dim);
  margin-bottom: 0.8rem;
  letter-spacing: 0.1em;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 0.8rem;
}

.card-title {
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  color: var(--text-bright);
  margin-bottom: 0.6rem;
  text-transform: uppercase;
}

.card-desc {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 1.2rem;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.1em;
  border-top: 1px solid var(--border-dim);
  padding-top: 0.75rem;
}

.meta-arrow {
  color: var(--accent-cyan);
  transition: transform 0.2s;
}

.project-card:hover .meta-arrow {
  transform: translateX(4px);
}

/* Corner decorations */
.card-corner-tl, .card-corner-br {
  position: absolute;
  width: 10px;
  height: 10px;
  border-color: var(--border-mid);
  border-style: solid;
  opacity: 0;
  transition: opacity 0.3s;
}

.card-corner-tl {
  top: 4px; left: 4px;
  border-width: 1px 0 0 1px;
}

.card-corner-br {
  bottom: 4px; right: 4px;
  border-width: 0 1px 1px 0;
}

.project-card:hover .card-corner-tl,
.project-card:hover .card-corner-br {
  opacity: 1;
}

/* ─── ARTICLE LIST ─── */
.articles-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: var(--border-dim);
  border: 1px solid var(--border-dim);
}

.article-row {
  display: grid;
  grid-template-columns: 60px 110px 1fr auto 24px;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem 1.4rem;
  background: var(--bg-panel);
  text-decoration: none;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

@media (max-width: 720px) {
  .article-row {
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  .article-index, .article-date, .article-arrow { display: none; }
  .article-tags { flex-direction: row; }
}

.article-row::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--accent-cyan);
  transform: scaleY(0);
  transition: transform 0.2s ease;
}

.article-row:hover {
  background: var(--bg-panel-hover);
}

.article-row:hover::before {
  transform: scaleY(1);
}

.article-index {
  font-family: var(--font-terminal);
  font-size: 1rem;
  color: var(--text-dim);
  letter-spacing: 0.05em;
}

.article-date {
  font-size: 0.7rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.article-info {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  overflow: hidden;
}

.article-title {
  font-family: var(--font-display);
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  color: var(--text-bright);
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.article-desc {
  font-size: 0.73rem;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.article-tags {
  display: flex;
  gap: 0.4rem;
  justify-content: flex-end;
}

.article-arrow {
  color: var(--text-dim);
  font-size: 0.85rem;
  transition: all 0.2s;
  justify-self: end;
}

.article-row:hover .article-arrow {
  color: var(--accent-cyan);
  transform: translateX(3px);
}
</style>
