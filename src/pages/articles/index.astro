---
// src/pages/articles/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));
---

<BaseLayout title="Articles" section="articles">
  <div class="page-header">
    <h1>Articles</h1>
    <p class="meta">{entries.length} {entries.length === 1 ? 'article' : 'articles'}</p>
  </div>

  <ul class="index-list">
    {entries.map(entry => (
      <li style="display: block; padding: 1.2rem 0;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;">
          <a href={`/articles/${entry.slug}`}>
            <span class="item-title" style="font-size: 0.9rem;">{entry.data.title}</span>
          </a>
          <span class="item-meta">{entry.data.date}</span>
        </div>
        {entry.data.description && (
          <p class="text-dim" style="margin-top: 0.3rem; margin-bottom: 0; font-size: 0.82rem;">
            {entry.data.description}
          </p>
        )}
        <div style="margin-top: 0.5rem;">
          {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
