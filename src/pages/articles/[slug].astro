---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('articles', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'articles'> };
const { Content } = await entry.render();
const { bsky } = entry.data;
---

<EntryLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  section="Articles"
  sectionHref="/articles"
>
  <Content />

  {bsky && (
    <div style="margin-top: 3rem; border-top: 1px solid var(--border); padding-top: 2rem;">
      <div class="section-label">Comments</div>
      <link rel="stylesheet" href="https://unpkg.com/bluesky-comments@0.12.0/dist/bluesky-comments.css">
      <div id="bluesky-comments"></div>
      <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
      <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
      <script src="https://unpkg.com/bluesky-comments@0.12.0/dist/bluesky-comments.umd.js"></script>
      <script define:vars={{ bsky }}>
        const container = document.getElementById('bluesky-comments');
        const root = ReactDOM.createRoot(container);
        root.render(React.createElement(BlueskyComments.BlueskyComments, { uri: bsky }));
      </script>
    </div>
  )}
</EntryLayout>