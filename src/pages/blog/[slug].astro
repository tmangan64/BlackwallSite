---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const files = await Astro.glob('../../content/blog/*.md');
  return files.map(f => ({
    params: { slug: f.file.split('/').pop()?.replace('.md', '') },
    props: { post: f },
  }));
}

const { post } = Astro.props;
const { frontmatter, Content } = post;

// Estimate reading time
const wordCount = post.rawContent().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={`${frontmatter.title} — [SYSTEM]`} description={frontmatter.description}>
  <div class="container page-wrap">

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">~/</a>
      <span class="bc-sep">/</span>
      <a href="/#articles">articles</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">{Astro.params.slug}</span>
    </nav>

    <!-- Article header -->
    <header class="article-header">
      <div class="ah-top-bar">
        <span class="ah-type">ARTICLE TRANSMISSION</span>
        <span class="ah-id">ID:{String(Math.floor(Math.random() * 0xFFFF)).padStart(4,'0').toUpperCase()}</span>
      </div>

      <div class="ah-body">
        <div class="ah-meta-row">
          <span class="ah-date">{new Date(frontmatter.date).toISOString().slice(0, 10)}</span>
          <span class="ah-sep">///</span>
          <span class="ah-reading">{readingTime} MIN READ</span>
          <span class="ah-sep">///</span>
          <span class="ah-words">{wordCount} WORDS</span>
        </div>

        <h1 class="ah-title">{frontmatter.title}</h1>
        <p class="ah-desc">{frontmatter.description}</p>

        <div class="ah-tags">
          {frontmatter.tags?.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Side transmission block -->
      <div class="ah-side">
        <div class="side-block">
          <div class="side-label">SIGNAL</div>
          <div class="side-bars">
            {[5, 4, 5, 3, 4, 5, 2, 4].map(h => (
              <div class="side-bar" style={`height: ${h * 6}px`}></div>
            ))}
          </div>
        </div>
        <div class="side-classify">
          <span>CLR: PUBLIC</span>
          <span>ENC: NONE</span>
        </div>
      </div>
    </header>

    <!-- Content -->
    <article class="prose article-body">
      <Content />
    </article>

    <!-- Footer nav -->
    <div class="article-footer">
      <div class="af-eof">
        <span class="af-line"></span>
        <span class="af-text">// END OF TRANSMISSION</span>
        <span class="af-line"></span>
      </div>
      <a href="/#articles" class="btn">← RETURN TO INDEX</a>
    </div>

  </div>
</BaseLayout>

<style>
.page-wrap {
  padding-top: 3rem;
  padding-bottom: 5rem;
}

.breadcrumb {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  margin-bottom: 2.5rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.breadcrumb a { color: var(--text-secondary); }
.breadcrumb a:hover { color: var(--accent-cyan); }
.bc-sep { color: var(--text-dim); }
.bc-current { color: var(--accent-cyan); }

/* Header */
.article-header {
  border: 1px solid var(--border-mid);
  background: var(--bg-panel);
  margin-bottom: 3rem;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.ah-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 1.5rem;
  background: rgba(0, 245, 255, 0.05);
  border-bottom: 1px solid var(--border-dim);
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.ah-type { color: var(--accent-cyan); }
.ah-id { color: var(--text-dim); font-family: var(--font-terminal); font-size: 0.9rem; }

.ah-body {
  padding: 2rem 1.5rem;
  flex: 1;
}

.ah-meta-row {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-bottom: 1.2rem;
}

.ah-sep { color: var(--border-mid); }

.ah-title {
  font-size: clamp(1.5rem, 4vw, 2.4rem);
  line-height: 1.1;
  letter-spacing: 0.04em;
  color: var(--text-bright);
  margin-bottom: 1rem;
  text-transform: uppercase;
  max-width: 26ch;
}

.ah-desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  max-width: 58ch;
  margin-bottom: 1.5rem;
}

.ah-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.ah-side {
  position: absolute;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.8rem;
  opacity: 0.4;
}

@media (max-width: 640px) { .ah-side { display: none; } }

.side-block { display: flex; flex-direction: column; gap: 0.4rem; align-items: flex-end; }
.side-label { font-size: 0.55rem; letter-spacing: 0.2em; color: var(--accent-cyan); }
.side-bars { display: flex; align-items: flex-end; gap: 2px; }
.side-bar {
  width: 4px;
  background: var(--accent-cyan);
  opacity: 0.7;
}

.side-classify {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  color: var(--text-dim);
  gap: 0.2rem;
}

/* Article body */
.article-body {
  padding-left: 2.5rem;
  border-left: 2px solid var(--border-dim);
  position: relative;
}

.article-body::before {
  content: '';
  position: absolute;
  left: -2px;
  top: 0;
  width: 2px;
  height: 40px;
  background: var(--accent-cyan);
  box-shadow: var(--glow-cyan);
}

/* Footer */
.article-footer {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.af-eof {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.15em;
}

.af-line {
  flex: 1;
  height: 1px;
  background: var(--border-dim);
}
</style>
