---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" section="about">
  <div class="page-header">
    <h1>About</h1>
  </div>

  <div class="prose">
    <p>
      My name is Teague (pronounced 'T -eeg') and I am a computer scientist from the UK. My degree is in Cyber Security and my work revolves around the following areas:
    </p>

    <ul>
      <li>Data Sovereignty</li>
      <li>Permacomputing</li>
      <li>Decentralisation</li>
    </ul>

    <h2>Structure</h2>

    <p>
      The site is organised into five sections:
    </p>

    <ul>
      <li><a href="/knowledge">Knowledge</a> — useful information I've saved</li>
      <li><a href="/articles">Articles</a> — letters and essays I've written</li>
      <li><a href="/projects">Projects</a> — current and past work</li>
      <li><a href="/resources">Resources</a> — tools, sites, and materials worth knowing</li>
      <li><a href="/about">About</a> — this page</li>
    </ul>

    <h2>Philosophy</h2>

    <p>
      Inspired by the wiki format of <a href="https://100r.co" target="_blank" rel="noopener">Hundred Rabbits</a>
      and the personal sites of the indie web. The goal for the site is to showcase my work as well as act as a hub for the resources I've gathered.
    </p>

    <h2>Technical</h2>

    <p>
      Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
      Content written in Markdown. Deployed as static HTML.
      The full source is <a href="https://www.github.com/tmangan64/BlackwallSite" target="_blank" rel="noopener">here</a>.
    </p>

    <h2></h2>
  </div>
</BaseLayout>
